# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://amishaaaaaa045_db_user:JGxCfdKovgDsPCgc@cluster0.5mzey5h.mongodb.net/

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=30d
JWT_COOKIE_EXPIRES_DAYS=30

# CORS
CLIENT_URL=http://localhost:3000

# Khalti Payment Gateway (https://docs.khalti.com/khalti-epayment/)
# Use your test secret key while developing, and your live key in production.
# NEVER commit real keys or expose the secret key to the frontend.
KHALTI_SECRET_KEY=your_khalti_secret_key_here
KHALTI_BASE_URL=https://a.khalti.com/api/v2/epayment
# Where Khalti redirects the user after completing/cancelling payment
KHALTI_RETURN_URL=http://localhost:3000/payment/callback
# Your frontend's base URL, required by Khalti's initiate API
KHALTI_WEBSITE_URL=http://localhost:3000

# Email (Nodemailer)
# Option A — named service (simplest for Gmail/Outlook/Yahoo etc.):
#   EMAIL_SERVICE=gmail
#   For Gmail, EMAIL_PASSWORD must be an "App Password", not your normal
#   account password: https://myaccount.google.com/apppasswords
# Option B — generic SMTP host (e.g. Mailtrap, SendGrid SMTP, Amazon SES):
#   leave EMAIL_SERVICE blank and set EMAIL_HOST/EMAIL_PORT instead.
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_app_password
# Shown as the email's display name and used as the fallback "from" address
EMAIL_FROM_NAME=Our Store
EMAIL_FROM_ADDRESS=your_email@example.com

# Image Storage — "local" (disk, served via /uploads) or "cloudinary"
STORAGE_PROVIDER=local

# Only required when STORAGE_PROVIDER=cloudinary
# https://cloudinary.com/documentation/node_integration#configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ------------ Security ------------
# See SECURITY.md for a full description of each mechanism below.

# Password hashing cost factor (bcrypt). Higher = slower to compute =
# more resistant to offline brute-forcing, at the cost of CPU time per
# login/registration. 12 is a reasonable default in 2026; increase over
# time as hardware gets faster.
BCRYPT_SALT_ROUNDS=12

# Password policy: how many previous passwords to block re-use of, and
# how many days before a password must be changed (0 disables expiry).
PASSWORD_HISTORY_LIMIT=5
PASSWORD_EXPIRY_DAYS=90

# Account-lockout brute-force protection (per-account, complements the
# IP-based rate limiting below).
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30

# 32+ character secret used to derive the AES-256-GCM key for encrypting
# sensitive fields at rest (currently: phone numbers — see
# utils/encryption.js). In production, source this from a secrets
# manager/KMS rather than a plain .env file, and never reuse JWT_SECRET
# for this. Losing this key makes encrypted data permanently unreadable.
ENCRYPTION_KEY=change_this_to_a_long_random_32_byte_secret

# Session/cookie behavior
COOKIE_SAME_SITE=lax
# Binds a session's JWT to the browser/device it was issued to (adds a
# User-Agent fingerprint claim, checked on every request). Optional/
# advanced — off by default since it can be too strict across some
# browser auto-updates. See SECURITY.md.
BIND_SESSION_TO_USER_AGENT=false

# System-wide brute-force protection (middleware/security.js)
# Comma-separated IP allow/block lists. Blocked IPs are rejected
# outright; allow-listed IPs bypass rate limiting entirely.
BLOCKED_IPS=
ALLOWED_IPS=
# Requests per 15-minute window (global baseline)
RATE_LIMIT_GLOBAL_MAX=300
# Requests per 15-minute window on auth endpoints (login/register/reset/passwordless)
RATE_LIMIT_AUTH_MAX=10
# Requests per 60-minute window on other sensitive endpoints (admin, orders, payments)
RATE_LIMIT_SENSITIVE_MAX=30
# Set to "true" only when running behind a reverse proxy/load balancer,
# so req.ip reflects the real client IP instead of the proxy's.
TRUST_PROXY=false
